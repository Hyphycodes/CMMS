# Proof CMMS — environment
#
# The app runs with ZERO configuration using the in-browser local data source
# (deterministic seed, deltas persisted to localStorage). Copy this file to
# `.env.local` ONLY when you want to wire the Supabase backend.

# Data source: "local" (default, no setup) or "supabase"
VITE_DATA_SOURCE=local

# Supabase (only needed when VITE_DATA_SOURCE=supabase)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side only — used by `npm run seed:supabase` to push the seed.
# NEVER expose the service role key to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
